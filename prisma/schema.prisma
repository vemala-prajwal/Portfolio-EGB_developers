generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      String   @default("ADMIN")
  createdAt DateTime @default(now())
}

model Project {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  subtitle    String   @default("")
  category    String
  industry    String   @default("")
  description String
  image       String
  stack       String   @default("[]")
  results     String   @default("")
  size        String   @default("medium")
  problem     String   @default("")
  solution    String   @default("")
  technology  String   @default("")
  outcome     String   @default("")
  impact      String   @default("")
  metrics     String   @default("[]")
  demoUrl     String?
  githubUrl   String?
  published   Boolean  @default(true)
  featured    Boolean  @default(true)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Service {
  id       String  @id @default(cuid())
  title    String
  subtitle String
  price    String
  features String  @default("[]")
}

model Testimonial {
  id      String @id @default(cuid())
  author  String
  company String
  quote   String
}

model Achievement {
  id    String @id @default(cuid())
  label String
  date  String
}

model BlogPost {
  id        String   @id @default(cuid())
  title     String
  category  String
  excerpt   String
  body      String
  published Boolean  @default(false)
  createdAt DateTime @default(now())
}

model SeoSetting {
  id          String @id @default(cuid())
  title       String
  description String
  ogImage     String
  keywords    String
}

model ContactDetail {
  id       String @id @default(cuid())
  email    String
  phone    String
  whatsapp String
  address  String
}

model SocialLink {
  id    String @id @default(cuid())
  label String
  url   String
}

model Media {
  id       String @id @default(cuid())
  url      String
  alt      String
  category String
}
